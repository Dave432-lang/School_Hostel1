# Environment Variables — School Hostel Booking System
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Server
PORT=5000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_hostel
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=hostel_super_secret_key_change_this_in_production
JWT_EXPIRES=7d
